generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  ADMIN
  ANALYST
  VIEWER
}

enum FeedbackSource {
  MANUAL
  CSV
  SIMULATED
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
  MIXED
}

enum ReportStatus {
  DRAFT
  GENERATING
  READY
  FAILED
}

model Workspace {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(120)
  slug      String   @unique @db.VarChar(140)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users      User[]
  feedback   Feedback[]
  themes     Theme[]
  reports    Report[]
  embeddings Embedding[]

  @@map("workspaces")
}

model User {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  email       String        @unique @db.VarChar(255)
  password    String        @db.VarChar(255)
  fullName    String?       @map("full_name") @db.VarChar(160)
  role        WorkspaceRole @default(ADMIN)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("users")
}

model Feedback {
  id          String         @id @default(uuid()) @db.Uuid
  workspaceId String         @map("workspace_id") @db.Uuid
  content     String
  source      FeedbackSource
  sentiment   Sentiment?
  metadata    Json           @default("{}")
  submittedAt DateTime       @default(now()) @map("submitted_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  themes    FeedbackTheme[]

  @@index([workspaceId, submittedAt(sort: Desc)])
  @@index([workspaceId, sentiment])
  @@map("feedback")
}

model Theme {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  name        String   @db.VarChar(180)
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  feedback  FeedbackTheme[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("themes")
}

model FeedbackTheme {
  feedbackId String @map("feedback_id") @db.Uuid
  themeId    String @map("theme_id") @db.Uuid

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  theme    Theme    @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@id([feedbackId, themeId])
  @@map("feedback_themes")
}

model Report {
  id          String       @id @default(uuid()) @db.Uuid
  workspaceId String       @map("workspace_id") @db.Uuid
  title       String       @db.VarChar(200)
  status      ReportStatus @default(DRAFT)
  content     Json?
  generatedAt DateTime?    @map("generated_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("reports")
}

model Embedding {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  feedbackId  String?  @map("feedback_id") @db.Uuid
  content     String
  vector      Unsupported("vector")?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([feedbackId])
  @@map("embeddings")
}
