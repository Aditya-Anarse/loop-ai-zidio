generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  ADMIN
  ANALYST
  VIEWER
}

enum FeedbackSource {
  MANUAL
  CSV
  SIMULATED
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
  MIXED
}

enum ReportStatus {
  DRAFT
  GENERATING
  READY
  FAILED
}

model Workspace {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(120)
  slug      String   @unique @db.VarChar(140)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users      User[]
  feedback   Feedback[]
  themes     Theme[]
  reports    Report[]
  embeddings Embedding[]
  integrations      Integration[]
  integrationEvents IntegrationEvent[]
  webhookLogs       WebhookLog[]
  auditLogs         IntegrationAuditLog[]

  @@map("workspaces")
}

model User {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  email       String        @unique @db.VarChar(255)
  password    String        @db.VarChar(255)
  fullName    String?       @map("full_name") @db.VarChar(160)
  role        WorkspaceRole @default(ADMIN)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("users")
}

model Feedback {
  id          String         @id @default(uuid()) @db.Uuid
  workspaceId String         @map("workspace_id") @db.Uuid
  content     String
  source      FeedbackSource
  sentiment   Sentiment?
  metadata    Json           @default("{}")
  submittedAt DateTime       @default(now()) @map("submitted_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  themes    FeedbackTheme[]

  @@index([workspaceId, submittedAt(sort: Desc)])
  @@index([workspaceId, sentiment])
  @@map("feedback")
}

model Theme {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  name        String   @db.VarChar(180)
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  feedback  FeedbackTheme[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("themes")
}

model FeedbackTheme {
  feedbackId String @map("feedback_id") @db.Uuid
  themeId    String @map("theme_id") @db.Uuid

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  theme    Theme    @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@id([feedbackId, themeId])
  @@map("feedback_themes")
}

model Report {
  id          String       @id @default(uuid()) @db.Uuid
  workspaceId String       @map("workspace_id") @db.Uuid
  title       String       @db.VarChar(200)
  status      ReportStatus @default(DRAFT)
  content     Json?
  generatedAt DateTime?    @map("generated_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("reports")
}

model Embedding {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  feedbackId  String?  @map("feedback_id") @db.Uuid
  content     String
  vector      Unsupported("vector")?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([feedbackId])
  @@map("embeddings")
}

model Integration {
  id              String   @id @default(uuid()) @db.Uuid
  workspaceId     String   @map("workspace_id") @db.Uuid
  type            String   @db.VarChar(50)
  enabled         Boolean  @default(false)
  status          String   @default("Disconnected") @db.VarChar(50)
  encryptedConfig String   @default("{}") @map("encrypted_config") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  workspace       Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  webhookLogs     WebhookLog[]
  auditLogs       IntegrationAuditLog[]

  @@unique([workspaceId, type])
  @@index([workspaceId])
  @@map("integrations")
}

model IntegrationEvent {
  id             String    @id @default(uuid()) @db.Uuid
  eventId        String    @default(uuid()) @map("event_id") @db.Uuid
  workspaceId    String    @map("workspace_id") @db.Uuid
  feedbackId     String?   @map("feedback_id") @db.Uuid
  idempotencyKey String    @unique @map("idempotency_key") @db.VarChar(255)
  eventType      String    @map("event_type") @db.VarChar(100)
  payload        Json
  status         String    @default("PENDING") @db.VarChar(50)
  attempts       Int       @default(0)
  maxAttempts    Int       @default(3) @map("max_attempts")
  nextAttemptAt  DateTime? @map("next_attempt_at")
  lastAttemptAt  DateTime? @map("last_attempt_at")
  processedAt    DateTime? @map("processed_at")
  error          String?   @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  webhookLogs WebhookLog[]

  @@index([workspaceId, status])
  @@index([status, nextAttemptAt])
  @@index([idempotencyKey])
  @@map("integration_events")
}

model WebhookLog {
  id            String   @id @default(uuid()) @db.Uuid
  workspaceId   String   @map("workspace_id") @db.Uuid
  integrationId String?  @map("integration_id") @db.Uuid
  eventId       String?  @map("event_id") @db.Uuid
  feedbackId    String?  @map("feedback_id") @db.Uuid
  url           String   @db.VarChar(500)
  event         String   @db.VarChar(100)
  payload       Json
  signature     String?  @db.VarChar(255)
  status        String   @db.VarChar(50)
  statusCode    Int?     @map("status_code")
  response      String?  @db.Text
  attempts      Int      @default(1)
  durationMs    Int?     @map("duration_ms")
  retryReason   String?  @map("retry_reason") @db.Text
  error         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  integration      Integration?      @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  integrationEvent IntegrationEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([status])
  @@map("webhook_logs")
}

model IntegrationAuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  workspaceId   String   @map("workspace_id") @db.Uuid
  integrationId String?  @map("integration_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  userName      String?  @map("user_name") @db.VarChar(160)
  userEmail     String?  @map("user_email") @db.VarChar(255)
  action        String   @db.VarChar(100)
  previousState Json?    @map("previous_state")
  newState      Json?    @map("new_state")
  createdAt     DateTime @default(now()) @map("created_at")

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  integration Integration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("integration_audit_logs")
}


